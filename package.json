{
  "name": "millipede",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:academy": "pnpm --filter @millipede/academy dev",
    "build:academy": "pnpm --filter @millipede/academy build",
    "dev:radar": "pnpm --filter @millipede/radar dev",
    "build:widgets": "pnpm --filter @millipede/lesson-widgets build",
    "compose:up": "docker compose -f infra/docker/docker-compose.yml up -d",
    "compose:down": "docker compose -f infra/docker/docker-compose.yml down",
    "ingestion:dev": "cargo run -p millipede-ingestion"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
