---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const lessons = (await getCollection("lessons")).sort((a, b) =>
  a.data.id.localeCompare(b.data.id, undefined, { numeric: true }),
);
---

<BaseLayout title="Millipede Academy">
  <section class="hero">
    <h1>Millipede Academy</h1>
    <p>Learn fundamentals. Ship Team Radar. Teach the class.</p>
  </section>

  <section>
    <h2>Book 0 — Foundations</h2>
    <ul class="lesson-list">
      {
        lessons.map((lesson) => (
          <li>
            <a href={`/lessons/${lesson.slug}/`}>
              <span class="lesson-id">{lesson.data.id}</span>
              {lesson.data.title}
            </a>
            <span class="meta">{lesson.data.duration_min ?? 30} min</span>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

<style>
  .hero {
    margin-bottom: 2rem;
  }
  .hero h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }
  .lesson-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }
  .lesson-list a {
    color: #38bdf8;
    text-decoration: none;
    font-weight: 600;
  }
  .lesson-list li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 1rem;
    background: #1e293b;
    border-radius: 8px;
    border: 1px solid #334155;
  }
  .lesson-id {
    display: inline-block;
    min-width: 2.5rem;
    color: #94a3b8;
    margin-right: 0.5rem;
  }
  .meta {
    color: #64748b;
    font-size: 0.875rem;
  }
</style>
