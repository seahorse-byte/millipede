---
interface Props {
  title: string;
}

const { title } = Astro.props;
import "@millipede/lesson-widgets/styles.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Millipede Academy — interactive DevSecOps learning" />
    <title>{title} | Millipede Academy</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/">Millipede Academy</a>
      <nav>
        <a href="/">Lessons</a>
        <a href="https://github.com" rel="noopener">GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    font-family: ui-sans-serif, system-ui, sans-serif;
    background: #0f172a;
    color: #e2e8f0;
    line-height: 1.6;
  }
  * {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    min-height: 100vh;
  }
  main {
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  a {
    color: #38bdf8;
  }
  code {
    font-family: ui-monospace, monospace;
    background: #1e293b;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
  }
  pre code {
    display: block;
    padding: 1rem;
    overflow-x: auto;
  }
</style>

<style>
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    border-bottom: 1px solid #334155;
    background: #0b1220;
  }
  .site-header a {
    color: #e2e8f0;
    text-decoration: none;
    font-weight: 600;
  }
  nav {
    display: flex;
    gap: 1rem;
  }
</style>
